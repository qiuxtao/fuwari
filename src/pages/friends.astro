---
import MainGridLayout from "../layouts/MainGridLayout.astro";
import { siteConfig } from "../config";

// 1. 定义友链数据
const friends = [
  {
    title: "薄荷の小屋",
    url: "https://www.hoshiroko.com",
    avatar: "https://api.hoshiroko.com/img/avatar.jpg",
    description: "越是拼命往前伸手，渴望之物越是渐行渐远"
  },
  {
    title: "夏沫花火zzz",
    url: "https://1l1.icu",
    avatar: "https://blog.1l1.icu/images/avatar.jpg",
    description: "Keep doing,keep loving."
  },
  // 在这里继续添加更多好友...
];

// 2. 随机打乱函数
function shuffleArray(array: any[]) {
    const newArray = [...array];
    for (let i = newArray.length - 1; i > 0; i--) {
        const j = Math.floor(Math.random() * (i + 1));
        [newArray[i], newArray[j]] = [newArray[j], newArray[i]];
    }
    return newArray;
}

const shuffledFriends = shuffleArray(friends);
---

<MainGridLayout title="友链" description="我的朋友们">
  <div class="flex w-full rounded-[var(--radius-large)] overflow-hidden relative min-h-32">
    <div class="card-base z-10 px-9 py-6 relative w-full">
      
      <h1 class="text-2xl font-bold mb-4 text-black/90 dark:text-white/90">友链</h1>
      
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        {shuffledFriends.map((friend) => (
          <a 
            href={friend.url} 
            target="_blank" 
            rel="noopener noreferrer"
            class="group flex items-center p-4 rounded-lg bg-[var(--card-bg)] hover:bg-[var(--btn-regular-bg-hover)] transition-all border border-black/5 dark:border-white/10 hover:scale-[1.02]"
          >
             <img src={friend.avatar} alt={friend.title} class="w-14 h-14 rounded-full mr-4 object-cover shadow-sm bg-white" />
             <div class="flex flex-col min-w-0">
               <span class="font-bold text-lg text-black/75 dark:text-white/75 group-hover:text-[var(--primary)] transition-colors truncate">{friend.title}</span>
               <span class="text-sm text-black/40 dark:text-white/40 truncate">{friend.description}</span>
             </div>
          </a>
        ))}
      </div>

      <hr class="my-8 border-black/10 dark:border-white/10 dashed" />

      <div class="grid grid-cols-1 md:grid-cols-2 gap-8 text-black/75 dark:text-white/75">
          
          <div>
              <h2 class="text-xl font-bold mb-4 text-[var(--primary)]">本站信息</h2>
              <div class="bg-black/5 dark:bg-white/5 p-4 rounded-lg text-sm border border-black/5 dark:border-white/10 leading-relaxed">
                  <div class="mb-2"><span class="font-bold opacity-70">标题：</span>{siteConfig.title}</div>
                  <div class="mb-2"><span class="font-bold opacity-70">介绍：</span>嗨，别来无恙啊！</div>
                  <div class="mb-2"><span class="font-bold opacity-70">链接：</span>https://qiuxiaotao.com</div>
                  <div><span class="font-bold opacity-70">头像：</span>https://qiuxiaotao.com/avatar.jpg</div>
              </div>
          </div>

          <div>
            <h2 class="text-xl font-bold mb-4 text-[var(--primary)]">申请说明</h2>
            <ul class="list-disc list-inside space-y-1 text-sm mb-4 opacity-80">
                <li>无侵入性广告</li>
                <li>支持 HTTPS</li>
                <li>有原创内容（拒绝纯导航站）</li>
                <li>接受本站镜像缓存图标</li>
            </ul>
            <p class="text-sm">
                如果你也想和我交换友链，欢迎随时联系我：
                <a href="mailto:nya@qiuxiaotao.com" class="text-[var(--primary)] hover:underline font-bold">nya@qiuxiaotao.com</a>
            </p>
          </div>

      </div>

    </div>
  </div>
</MainGridLayout>