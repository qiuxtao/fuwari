---
import MainGridLayout from "../layouts/MainGridLayout.astro";
import { siteConfig } from "../config";
import FriendList from "../components/FriendList.svelte";
import { Icon } from "astro-icon/components";

// 1. 定义友链数据
const friends = [
  {
    title: "薄荷の小屋",
    url: "https://www.hoshiroko.com",
    avatar: "https://api.hoshiroko.com/img/avatar.jpg",
    description: "越是拼命往前伸手，渴望之物越是渐行渐远"
  },
  {
    title: "夏沫花火zzz",
    url: "https://1l1.icu",
    avatar: "https://blog.1l1.icu/images/avatar.jpg",
    description: "Keep doing,keep loving."
  },
  // 在这里继续添加更多好友...
];
---

<MainGridLayout title="朋友们" description="我的朋友们">
  <div class="flex w-full rounded-[var(--radius-large)] overflow-hidden relative min-h-32">
    <div class="card-base z-10 px-9 py-6 relative w-full">
      
      <h1 class="text-2xl font-bold mb-4 text-black/90 dark:text-white/90">朋友们</h1>
      
      <FriendList client:only="svelte" friends={friends} />

      <hr class="my-8 border-black/10 dark:border-white/10 dashed" />

      <div class="grid grid-cols-1 lg:grid-cols-2 gap-6 mt-8">
          
          <!-- Site Info Card -->
          <div class="group relative bg-black/[0.02] dark:bg-white/[0.02] border border-black/5 dark:border-white/5 rounded-2xl p-6 transition-all hover:border-[var(--primary)]/50 hover:bg-black/[0.03] dark:hover:bg-white/[0.03]">
              <div class="flex items-center gap-2 text-lg font-bold mb-5 text-[var(--primary)] drop-shadow-sm">
                  <Icon name="material-symbols:info-outline-rounded" class="text-2xl" />
                  本站信息
              </div>
              
              <div class="space-y-4">
                  <div class="flex flex-col sm:flex-row sm:items-center gap-1 sm:gap-3 text-sm">
                      <span class="text-neutral-500 dark:text-neutral-400 font-bold min-w-[3.5rem] flex items-center gap-1">
                          <Icon name="material-symbols:title-rounded" class="text-lg opacity-70" />标题
                      </span>
                      <span class="font-medium text-neutral-800 dark:text-neutral-200">{siteConfig.title}</span>
                  </div>
                  <div class="flex flex-col sm:flex-row sm:items-start gap-1 sm:gap-3 text-sm">
                      <span class="text-neutral-500 dark:text-neutral-400 font-bold min-w-[3.5rem] flex items-center gap-1 mt-0.5">
                          <Icon name="material-symbols:edit-note-rounded" class="text-lg opacity-70" />介绍
                      </span>
                      <span class="font-medium text-neutral-800 dark:text-neutral-200 leading-relaxed">嗨，别来无恙啊！</span>
                  </div>
                  <div class="flex flex-col sm:flex-row sm:items-center gap-1 sm:gap-3 text-sm">
                      <span class="text-neutral-500 dark:text-neutral-400 font-bold min-w-[3.5rem] flex items-center gap-1">
                          <Icon name="material-symbols:link-rounded" class="text-lg opacity-70" />链接
                      </span>
                      <code class="px-2 py-0.5 bg-black/5 dark:bg-white/10 rounded font-mono text-neutral-700 dark:text-neutral-300 cursor-pointer hover:bg-black/10 dark:hover:bg-white/20 transition-colors tooltip tooltip-right group" data-copy-value="https://qiuxiaotao.com" role="button" tabindex="0" title="点击复制">https://qiuxiaotao.com</code>
                  </div>
                  <div class="flex flex-col sm:flex-row sm:items-center gap-1 sm:gap-3 text-sm">
                      <span class="text-neutral-500 dark:text-neutral-400 font-bold min-w-[3.5rem] flex items-center gap-1">
                          <Icon name="material-symbols:image-outline-rounded" class="text-lg opacity-70" />头像
                      </span>
                      <code class="px-2 py-0.5 bg-black/5 dark:bg-white/10 rounded font-mono text-neutral-700 dark:text-neutral-300 break-all cursor-pointer hover:bg-black/10 dark:hover:bg-white/20 transition-colors tooltip tooltip-right" data-copy-value="https://qiuxiaotao.com/avatar.jpg" role="button" tabindex="0" title="点击复制">https://qiuxiaotao.com/avatar.jpg</code>
                  </div>
              </div>
          </div>

          <!-- Application Instructions Card -->
          <div class="group relative bg-black/[0.02] dark:bg-white/[0.02] border border-black/5 dark:border-white/5 rounded-2xl p-6 transition-all hover:border-[var(--primary)]/50 hover:bg-black/[0.03] dark:hover:bg-white/[0.03]">
              <div class="flex items-center gap-2 text-lg font-bold mb-5 text-[var(--primary)] drop-shadow-sm">
                  <Icon name="material-symbols:handshake-outline-rounded" class="text-2xl" />
                  申请说明
              </div>
              
              <ul class="space-y-3 mb-6 text-[0.95rem] text-neutral-700 dark:text-neutral-300 font-medium">
                  <li class="flex items-center gap-2">
                      <Icon name="material-symbols:check-circle-outline-rounded" class="text-green-500 text-lg shrink-0" />
                      网站无侵入性广告、弹窗或恶意跳转
                  </li>
                  <li class="flex items-center gap-2">
                      <Icon name="material-symbols:lock-outline" class="text-green-500 text-lg shrink-0" />
                      至少支持 HTTPS 加密访问
                  </li>
                  <li class="flex items-center gap-2">
                      <Icon name="material-symbols:article-outline-rounded" class="text-green-500 text-lg shrink-0" />
                      包含原创优质内容 (拒绝纯导航收录站)
                  </li>
                  <li class="flex items-center gap-2">
                      <Icon name="material-symbols:network-check-rounded" class="text-blue-500 text-lg shrink-0" />
                      接受本站镜像缓存图标
                  </li>
              </ul>
              
              <div class="mt-auto text-sm font-medium text-neutral-700 dark:text-neutral-300 pt-2 border-t border-black/5 dark:border-white/5">
                  欢迎根据以上格式准备你的信息，并发送邮件联系我：
                  <a href="mailto:nya@qiuxiaotao.com" class="inline-flex mt-2 items-center px-3 py-1.5 bg-black/5 dark:bg-white/10 rounded-lg text-[var(--primary)] font-bold hover:bg-[var(--primary)] hover:text-white transition-colors">
                      nya@qiuxiaotao.com
                  </a>
              </div>
          </div>

      </div>

    </div>
  </div>
</MainGridLayout>

<script>
const copyFeedbackText = "已复制！";

function initCopyCodes() {
    document.querySelectorAll<HTMLElement>("[data-copy-value]").forEach((element) => {
        if (element.dataset.copyBound === "true") return;

        element.dataset.copyBound = "true";

        const copyText = async () => {
            const originalText = element.textContent ?? "";
            const textToCopy = element.dataset.copyValue ?? originalText.trim();

            await navigator.clipboard.writeText(textToCopy);
            element.textContent = copyFeedbackText;
            window.setTimeout(() => {
                element.textContent = originalText;
            }, 1500);
        };

        element.addEventListener("click", () => {
            void copyText();
        });

        element.addEventListener("keydown", (event) => {
            if (event.key !== "Enter" && event.key !== " ") return;

            event.preventDefault();
            void copyText();
        });
    });
}

initCopyCodes();
document.addEventListener("astro:page-load", initCopyCodes);
document.addEventListener("swup:contentReplaced", initCopyCodes);
</script>
