---
import { Icon } from 'astro-icon/components'

const links = [
    { name: '神秘小盘', url: 'https://pan.qiuxiaotao.com/', icon: 'fa6-solid:cloud' },
    { name: '监控站', url: 'https://status.qiuxiaotao.com/', icon: 'fa6-solid:server' },
    { name: '会议室', url: 'https://meeting.qiuxiaotao.cn/', icon: 'fa6-solid:comments' },
    { name: 'MC地图', url: 'https://mcmap.qiuxiaotao.com/', icon: 'fa6-solid:map' },
    { name: 'NextChat', url: 'https://gpt.qiuxiaotao.com/', icon: 'fa6-solid:robot' },
]
---

<div class="card-base p-4 w-full mb-4">
    <div class="font-bold text-lg mb-3 ml-1 text-neutral-900 dark:text-neutral-100 transition-colors">
        网站列表
    </div>
    
    <div class="grid grid-cols-2 gap-3">
        {links.map((item) => (
            <a 
                href={item.url} 
                target="_blank" 
                class="group flex items-center justify-center gap-2 p-3 rounded-xl 
                       /* 背景：默认状态 */
                       bg-black/5 dark:bg-white/10 
                       /* 悬浮状态：使用 !强制覆盖背景色，确保暗色模式生效 */
                       hover:!bg-[var(--primary)] 
                       /* 文字颜色：使用实色(neutral)代替透明度，避免闪烁 */
                       text-neutral-600 dark:text-neutral-400
                       hover:!text-white
                       /* 动画：只过渡颜色，时长缩短至 200ms 更跟手 */
                       transition-colors duration-200 ease-in-out"
            >
                <div class="text-lg transition-transform duration-200 group-hover:scale-110 group-hover:-rotate-6">
                    <Icon name={item.icon} />
                </div>
                <span class="font-medium text-sm">{item.name}</span>
            </a>
        ))}
    </div>
</div>